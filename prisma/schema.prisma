generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model HomePageContent {
  id                 String   @id @default("default_home")
  // Hero Section
  heroTitle          String
  heroSubtitle       String
  heroDescription    String   @db.Text
  heroVideo          String?
  heroImage          String?
  // Statistics Bar
  statsYearsExp      Int      @default(0)
  statsProjects      Int      @default(0)
  statsClients       Int      @default(0)
  statsExperts       Int      @default(0)
  // Welcome Section
  welcomeTitle       String
  welcomeDescription String   @db.Text
  welcomeImage       String?
  welcomeIcon        String?
  // CTA Section
  ctaTitle           String
  ctaDescription     String   @db.Text
  ctaBgImage         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AboutPageContent {
  id                    String   @id @default("default_about")
  // Hero Section
  title                 String
  subtitle              String?  @default("About Us")
  description           String   @db.Text
  bgImage               String?
  // Who We Are Section
  whoWeAreTitle         String?  @default("Providing Enterprise-Grade Connectivity & Defense")
  whoWeAreDescription1  String?  @db.Text
  whoWeAreDescription2  String?  @db.Text
  whoWeAreDescription3  String?  @db.Text
  whoWeAreImage         String?
  // Mission, Vision, Values
  values                Json?     // Array of { title, desc, icon }
  // Why Choose Us
  whyChooseUsTitle      String?  @default("Your Trusted Partner for Technology-Driven Transformation")
  whyChooseUsImage      String?
  benefits              Json?     // Array of { title, desc, icon }
  // Testimonials
  testimonials          Json?     // Array of { name, role, stars, quote }
  // CTA Section
  ctaTitle              String?  @default("Ready to Get Started?")
  ctaDescription        String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ContactInfo {
  id                 String   @id @default("default_contact")
  title              String
  description        String   @db.Text
  bgImage            String?
  bannerImage        String?
  email1             String
  email2             String?
  phone1             String
  phone2             String?
  address            String   @db.Text
  facebook           String?
  twitter            String?
  linkedin           String?
  instagram          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}



model Service {
  id                  String   @id @default(uuid())
  slug                String   @unique
  title               String
  subtitle            String
  description         String   @db.Text
  icon                String
  features            Json
  orderIndex          Int      @default(0)
  active              Boolean  @default(true)
  imageUrl            String?
  // Service Detail Page custom fields
  heroTitle           String?
  heroHighlight       String?
  heroDescription     String?  @db.Text
  heroImage           String?
  stats               Json?    // Array of { value, label }
  overviewTitle       String?
  overviewDescription String?  @db.Text
  overviewImage       String?
  partners            Json?    // Array of { name, imageUrl }
  projects            Json?    // Array of { category, title, description, image, link }
  faqs                Json?    // Array of { question, answer }
}

model Project {
  id          String   @id @default(uuid())
  title       String
  client      String
  category    String
  description String   @db.Text
  imageUrl    String?
  tags        Json
  featured    Boolean  @default(false)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
}


model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  message   String   @db.Text
  status    String   @default("new")
  ipAddress String?
  createdAt DateTime @default(now())
}
